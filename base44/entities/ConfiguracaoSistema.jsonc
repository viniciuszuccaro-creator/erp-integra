{
  "name": "ConfiguracaoSistema",
  "type": "object",
  "properties": {
    "chave": {
      "type": "string",
      "description": "Identificador \u00fanico da configura\u00e7\u00e3o"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "Empresa",
        "Fiscal",
        "Email",
        "Certificado",
        "Sistema",
        "Integracoes",
        "Comercial",
        "Financeiro",
        "Notificacoes",
        "Seguranca"
      ],
      "description": "Categoria da configura\u00e7\u00e3o"
    },
    "ativa": {
      "type": "boolean",
      "default": false,
      "description": "Estado do toggle (true=ligado, false=desligado)"
    },
    "valor": {
      "type": "string",
      "description": "Valor gen\u00e9rico (string) para configura\u00e7\u00f5es simples"
    },
    "numero": {
      "type": "number",
      "description": "Valor num\u00e9rico (timeout, limiar, etc)"
    },
    "group_id": {
      "type": "string",
      "description": "ID do grupo empresarial"
    },
    "empresa_id": {
      "type": "string",
      "description": "ID da empresa"
    },
    "dados_empresa": {
      "type": "object",
      "additionalProperties": true
    },
    "parametros_comerciais": {
      "type": "object",
      "additionalProperties": true
    },
    "parametros_fiscais": {
      "type": "object",
      "additionalProperties": true
    },
    "configuracoes_email": {
      "type": "object",
      "additionalProperties": true
    },
    "certificado_digital": {
      "type": "object",
      "additionalProperties": true
    },
    "integracao_nfe": {
      "type": "object",
      "additionalProperties": true
    },
    "integracao_boletos": {
      "type": "object",
      "additionalProperties": true
    },
    "integracao_transportadoras": {
      "type": "object",
      "additionalProperties": true
    },
    "integracao_whatsapp": {
      "type": "object",
      "additionalProperties": true
    },
    "integracao_maps": {
      "type": "object",
      "additionalProperties": true
    },
    "configuracoes_sistema": {
      "type": "object",
      "additionalProperties": true
    },
    "integracao_ia_producao": {
      "type": "object",
      "properties": {
        "ativada": {
          "type": "boolean",
          "default": false
        },
        "provedor": {
          "type": "string",
          "enum": [
            "Custom",
            "Azure OpenAI",
            "OpenAI",
            "Local",
            "Outro"
          ]
        },
        "endpoint_url": {
          "type": "string"
        },
        "api_key": {
          "type": "string"
        },
        "modelo": {
          "type": "string"
        },
        "timeout_segundos": {
          "type": "number",
          "default": 60
        },
        "gerar_op_automaticamente": {
          "type": "boolean",
          "default": false
        },
        "observacoes": {
          "type": "string"
        }
      }
    },
    "configuracoes_comerciais": {
      "type": "object",
      "additionalProperties": true
    },
    "configuracoes_financeiras": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "chave",
    "categoria"
  ]
}